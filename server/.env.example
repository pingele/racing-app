# Server config
PORT=4000
NODE_ENV=development

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# SQLite
DATABASE_PATH=./data/racing.sqlite

# Race provider: "mock" or "racemonitor"
RACE_PROVIDER=mock
RACE_MONITOR_BASE_URL=https://api.race-monitor.com
RACE_MONITOR_TOKEN=

# CORS
CLIENT_ORIGIN=http://localhost:5173
